{
  "dataset": "GSE157103",
  "random_state": 42,
  "expression_filter": {
    "min_tpm": 1,
    "min_counts": 10,
    "min_covid_samples_absolute": 5,
    "min_covid_samples_fraction": 0.10
  },
  "feature_selection": {
    "max_variable_genes": 3000
  },
  "pca": {
    "max_components": 30,
    "components_for_clustering": 20
  },
  "umap": {
    "n_neighbors": 15,
    "min_dist": 0.25
  },
  "clustering": {
    "kmeans_k": [2, 3, 4, 5, 6],
    "hierarchical_linkages": ["ward", "average", "complete"],
    "dbscan_eps_values": [1.0, 8.0, 0.5]
  },
  "enrichment": {
    "organism": "hsapiens",
    "sources": ["GO:BP", "REAC", "KEGG"],
    "max_genes_per_cluster": 150
  }
}

